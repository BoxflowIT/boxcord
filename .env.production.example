# Boxcord Production Environment Variables
# Set these in Railway dashboard

# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# CORS - set to your Railway app URL
CORS_ORIGIN=https://boxcord-production.up.railway.app

# JWT / Cognito (when ready)
# COGNITO_USER_POOL_ID=eu-north-1_xxxxx
# COGNITO_CLIENT_ID=your-client-id
# COGNITO_REGION=eu-north-1
JWT_SECRET=change-this-to-a-secure-random-string

# Boxtime API Integration (when available)
# BOXTIME_API_URL=https://boxtime.boxflow.com
