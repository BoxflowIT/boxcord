# Boxcord Environment Variables
# Copy this file to .env and fill in values

# Database
# Connection pool settings for high load:
# - connection_limit: Max connections (default: 10, recommended: 20-50 for production)
# - pool_timeout: Max time to wait for connection (default: 10s)
# - connect_timeout: Max time for initial connection (default: 5s)
DATABASE_URL="postgresql://boxcord:boxcord@localhost:5433/boxcord?schema=public&connection_limit=20&pool_timeout=10&connect_timeout=5"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT / Cognito (same as Boxtime)
COGNITO_USER_POOL_ID=eu-north-1_xxxxx
COGNITO_CLIENT_ID=your-client-id
COGNITO_REGION=eu-north-1
JWT_SECRET=your-jwt-secret-for-local-dev

# Boxtime API Integration
BOXTIME_API_URL=http://localhost:3000
# For production: https://boxtime.boxflow.com

# Optional: Redis Cache & Message Queue
# IMPORTANT: Redis enables two critical features for scaling:
# 1. WebSocket clustering - Required for running 2+ ECS tasks
# 2. Background job queue - Reliable email, webhook, notification processing
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Set to 'boxcord' when using docker-compose
REDIS_PASSWORD=
PRISMA_QUERY_CACHE_TTL=60

# Optional: Sentry Error Tracking
# Backend: Generate at https://sentry.io
SENTRY_DSN=

# Optional: Enable Swagger docs
SWAGGER_ENABLED=true

# Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@boxflow.com

# Optional: AWS S3 for File Storage
# Required for production with multiple servers
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=boxcord-uploads

# Optional: SendGrid Email Service
# For email notifications (mentions, DMs, invites)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@boxflow.com

# Optional: Microsoft 365 Integration (SharePoint, Calendar, OneDrive)
# Register an app in Azure AD → App registrations
# Requires: API permissions for Microsoft Graph (User.Read, Files.ReadWrite.All, etc.)
# App must have signInAudience=AzureADandPersonalMicrosoftAccount & tokenVersion=2
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=your-app-client-secret
# MS_TENANT_ID is optional — omit for multi-tenant (uses 'common' endpoint)
# Set to a specific tenant ID to restrict to one organization
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:3001/api/v1/integrations/microsoft/callback

# Optional: GitHub PAT for desktop release downloads
# Not needed for public repos — used by /api/desktop-releases endpoint
GH_PAT=
