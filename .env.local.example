# Local Development Environment
# Copy this to .env for local development

# Database (Docker Compose)
DATABASE_URL="postgresql://boxcord:boxcord@localhost:5433/boxcord?schema=public&connection_limit=20&pool_timeout=10&connect_timeout=5"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT / Cognito (use test values for local dev)
COGNITO_USER_POOL_ID=eu-north-1_test
COGNITO_CLIENT_ID=test-client-id
COGNITO_REGION=eu-north-1
JWT_SECRET=local-dev-secret-minimum-twenty-characters-long

# Boxtime API Integration (local)
BOXTIME_API_URL=http://localhost:3000

# Redis (Docker Compose)
REDIS_URL=redis://localhost:6379

# Optional: Email (use Ethereal for local testing)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional: VAPID for push notifications (generate with web-push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@boxflow.se

# Optional: Giphy (get free API key at developers.giphy.com)
VITE_GIPHY_API_KEY=

# Optional: Sentry (leave empty for local dev)
SENTRY_DSN=

# Optional: AWS S3 (for file uploads - use local storage in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_S3_BUCKET=
