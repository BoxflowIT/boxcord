# Boxcord Client Environment Variables
# Copy this file to .env.local and fill in values

# Sentry Error Tracking (Optional)
# Get your DSN from https://sentry.io
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Giphy API for GIF Picker (Optional but recommended)
# Get your API key from https://developers.giphy.com/
# 1. Create a free account
# 2. Create a new app (choose API, not SDK)
# 3. Copy the API key
# Without this, GIF picker will not appear
VITE_GIPHY_API_KEY=
