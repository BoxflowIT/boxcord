#!/bin/bash
# pre-commit hook - runs before commit is created

echo "🎨 Running lint-staged (ESLint + Prettier)..."
yarn lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Lint-staged failed!"
  exit 1
fi

echo ""
echo "🧪 Running tests..."

# Backend tests
echo "📦 Backend tests..."
yarn test --run
if [ $? -ne 0 ]; then
  echo "❌ Backend tests failed!"
  exit 1
fi

# Frontend tests  
echo "🎨 Frontend tests..."
cd client && yarn test --run
if [ $? -ne 0 ]; then
  echo "❌ Frontend tests failed!"
  exit 1
fi
cd ..

echo ""
echo "✅ All pre-commit checks passed!"
exit 0
