#!/bin/bash
# pre-commit hook - runs before commit is created
# Only lint-staged here — full tests run in pre-push and CI

echo "🎨 Running lint-staged (ESLint + Prettier)..."
yarn lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Lint-staged failed!"
  exit 1
fi

echo ""
echo "✅ Pre-commit checks passed!"
exit 0
