#!/bin/bash
# prepare-commit-msg hook
# Automatically adds emoji prefix based on conventional commit type

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Skip if this is a merge commit, squash, or amend
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
  exit 0
fi

# Read the commit message
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip if empty message
if [ -z "$COMMIT_MSG" ]; then
  exit 0
fi

# Get first line (subject) and rest of message
SUBJECT=$(echo "$COMMIT_MSG" | head -1)
REST=$(echo "$COMMIT_MSG" | tail -n +2)

# Check if subject already has emoji
if echo "$SUBJECT" | grep -qE '^[[:space:]]*(✨|🐛|♻️|📝|🧪|🔧|⚡|💄|👷|🔀|🔖|🔒)'; then
  exit 0
fi

# Extract commit type
TYPE=$(echo "$SUBJECT" | grep -oE '^(feat|fix|refactor|docs|test|chore|perf|style|ci|merge)' | head -1 || true)

# Map type to emoji
EMOJI=""
case "$TYPE" in
  "feat") EMOJI="✨" ;;
  "fix") EMOJI="🐛" ;;
  "refactor") EMOJI="♻️" ;;
  "docs") EMOJI="📝" ;;
  "test") EMOJI="🧪" ;;
  "chore") EMOJI="🔧" ;;
  "perf") EMOJI="⚡" ;;
  "style") EMOJI="💄" ;;
  "ci") EMOJI="👷" ;;
  "merge") EMOJI="🔀" ;;
esac

# Add emoji at the start if we found a matching type
if [ -n "$EMOJI" ]; then
  NEW_SUBJECT="$EMOJI $SUBJECT"
  if [ -z "$REST" ]; then
    echo "$NEW_SUBJECT" > "$COMMIT_MSG_FILE"
  else
    { echo "$NEW_SUBJECT"; echo "$REST"; } > "$COMMIT_MSG_FILE"
  fi
fi

exit 0
