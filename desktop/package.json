{
  "name": "boxcord-desktop",
  "version": "1.12.0",
  "description": "Boxcord Desktop — Discord-like chat for Boxflow",
  "author": "Boxflow IT <info@boxflow.se>",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:win": "yarn build && electron-builder --win",
    "build:mac": "yarn build && electron-builder --mac",
    "build:linux": "yarn build && electron-builder --linux",
    "build:all": "yarn build && electron-builder --win --mac --linux",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "se.boxflow.boxcord",
    "productName": "Boxcord",
    "directories": {
      "output": "out",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "BoxflowIT",
      "repo": "boxcord"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Chat"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
