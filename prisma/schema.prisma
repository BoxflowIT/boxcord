// Boxcord Database Schema
// Chat system for Boxflow integrated with Boxtime

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================
// USERS (local cache of Boxtime users)
// ============================================

model User {
    id          String    @id // Same as Cognito sub / Boxtime user.id
    email       String    @unique
    firstName   String?   @map("first_name")
    lastName    String?   @map("last_name")
    avatarUrl   String?   @map("avatar_url")
    bio         String?
    role        String    @default("STAFF") // SUPER_ADMIN | ADMIN | STAFF
    status      String? // Custom status message
    statusEmoji String?   @map("status_emoji") // Emoji for status
    dndMode     Boolean   @default(false) @map("dnd_mode") // Do Not Disturb
    dndUntil    DateTime? @map("dnd_until") // Temporary DND until specific time
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")

    presence             UserPresence?
    messages             Message[]
    directMessages       DirectMessage[]            @relation("DirectMessageAuthor")
    dmParticipants       DirectMessageParticipant[]
    workspaceMemberships WorkspaceMember[]
    bookmarks            BookmarkedMessage[]
    pushSubscriptions    PushSubscription[]
    voiceSessions        VoiceSession[]
    polls                Poll[]
    pollVotes            PollVote[]
    messageTemplates     MessageTemplate[]

    @@map("users")
}

// ============================================
// CHANNELS & WORKSPACES
// ============================================

model Workspace {
    id          String   @id @default(uuid())
    name        String
    description String?
    iconUrl     String?
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    channels          Channel[]
    channelCategories ChannelCategory[]
    members           WorkspaceMember[]
    invites           WorkspaceInvite[]
    bookmarks         BookmarkedMessage[]

    @@map("workspaces")
}

model WorkspaceMember {
    id          String     @id @default(uuid())
    workspaceId String     @map("workspace_id")
    userId      String     @map("user_id") // References Boxtime user.id (Cognito sub)
    role        MemberRole @default(MEMBER)
    isBanned    Boolean    @default(false) @map("is_banned")
    bannedAt    DateTime?  @map("banned_at")
    bannedBy    String?    @map("banned_by")
    banReason   String?    @map("ban_reason")
    joinedAt    DateTime   @default(now()) @map("joined_at")

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([workspaceId, userId], name: "workspaceId_userId")
    @@index([userId])
    @@index([workspaceId])
    @@map("workspace_members")
}

model WorkspaceInvite {
    id          String    @id @default(uuid())
    workspaceId String    @map("workspace_id")
    code        String    @unique // Short invite code like "abc123"
    createdBy   String    @map("created_by") // User who created the invite
    maxUses     Int?      @map("max_uses") // null = unlimited
    uses        Int       @default(0) // How many times used
    expiresAt   DateTime? @map("expires_at") // null = never expires
    createdAt   DateTime  @default(now()) @map("created_at")

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@index([code])
    @@map("workspace_invites")
}

model Channel {
    id          String      @id @default(uuid())
    workspaceId String      @map("workspace_id")
    categoryId  String?     @map("category_id") // Optional category grouping
    name        String
    description String?
    type        ChannelType @default(TEXT)
    isPrivate   Boolean     @default(false) @map("is_private")
    position    Int         @default(0) // For ordering within category
    createdAt   DateTime    @default(now()) @map("created_at")
    updatedAt   DateTime    @updatedAt @map("updated_at")

    workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    category      ChannelCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    messages      Message[]
    members       ChannelMember[]
    permissions   ChannelPermission[]
    voiceSessions VoiceSession[]
    polls         Poll[]
    webhooks      ChannelWebhook[]

    @@unique([workspaceId, name])
    @@index([workspaceId])
    @@index([categoryId])
    @@map("channels")
}

model ChannelCategory {
    id          String   @id @default(uuid())
    workspaceId String   @map("workspace_id")
    name        String
    position    Int      @default(0) // For ordering categories
    collapsed   Boolean  @default(false) // User can collapse categories
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    channels  Channel[]

    @@unique([workspaceId, name])
    @@index([workspaceId])
    @@map("channel_categories")
}

model ChannelMember {
    id         String    @id @default(uuid())
    channelId  String    @map("channel_id")
    userId     String    @map("user_id")
    joinedAt   DateTime  @default(now()) @map("joined_at")
    lastReadAt DateTime? @map("last_read_at") // Track when user last read messages

    channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

    @@unique([channelId, userId], name: "channelId_userId")
    @@index([channelId])
    @@index([userId])
    @@map("channel_members")
}

model ChannelPermission {
    id        String     @id @default(uuid())
    channelId String     @map("channel_id")
    role      MemberRole // Permission override for specific role

    // View permissions
    canViewChannel Boolean @default(true) @map("can_view_channel")

    // Message permissions
    canSendMessages    Boolean @default(true) @map("can_send_messages")
    canAddReactions    Boolean @default(true) @map("can_add_reactions")
    canAttachFiles     Boolean @default(true) @map("can_attach_files")
    canEmbed           Boolean @default(true) @map("can_embed") // Links with rich embeds
    canMentionEveryone Boolean @default(false) @map("can_mention_everyone")

    // Management permissions
    canManageMessages Boolean @default(false) @map("can_manage_messages") // Delete/pin others' messages
    canManageChannel  Boolean @default(false) @map("can_manage_channel") // Edit channel settings
    canManageMembers  Boolean @default(false) @map("can_manage_members") // Add/remove members

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

    @@unique([channelId, role], name: "channelId_role")
    @@index([channelId])
    @@map("channel_permissions")
}

// ============================================
// MESSAGES
// ============================================

model Message {
    id        String    @id @default(uuid())
    channelId String    @map("channel_id")
    authorId  String    @map("author_id") // References Boxtime user.id
    content   String
    edited    Boolean   @default(false)
    isPinned  Boolean   @default(false) @map("is_pinned")
    pinnedAt  DateTime? @map("pinned_at")
    pinnedBy  String?   @map("pinned_by") // User ID who pinned
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    // Reply threading
    parentId String?   @map("parent_id")
    parent   Message?  @relation("ThreadReplies", fields: [parentId], references: [id])
    replies  Message[] @relation("ThreadReplies")

    channel     Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
    author      User                @relation(fields: [authorId], references: [id])
    attachments Attachment[]
    reactions   Reaction[]
    bookmarks   BookmarkedMessage[]
    thread      Thread? // If this message starts a thread
    poll        Poll? // If this message has a poll

    @@index([channelId, createdAt])
    @@index([channelId, isPinned, createdAt]) // Optimize pinned message queries
    @@index([authorId])
    @@index([parentId]) // Optimize thread replies queries
    @@map("messages")
}

// Thread metadata for tracking thread state
model Thread {
    id               String    @id @default(uuid())
    messageId        String    @unique @map("message_id") // The root message that started the thread
    channelId        String    @map("channel_id")
    title            String? // Optional thread title
    replyCount       Int       @default(0) @map("reply_count")
    participantCount Int       @default(0) @map("participant_count")
    lastReplyAt      DateTime? @map("last_reply_at")
    lastReplyBy      String?   @map("last_reply_by") // User ID of last replier
    isLocked         Boolean   @default(false) @map("is_locked") // Prevent new replies
    isArchived       Boolean   @default(false) @map("is_archived") // Archived threads are read-only and hidden from main view
    isResolved       Boolean   @default(false) @map("is_resolved") // Resolved threads are marked as completed
    createdAt        DateTime  @default(now()) @map("created_at")
    updatedAt        DateTime  @updatedAt @map("updated_at")

    message      Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
    participants ThreadParticipant[]

    @@index([channelId, lastReplyAt])
    @@index([messageId])
    @@map("threads")
}

// Track which users are following/participating in a thread
model ThreadParticipant {
    id            String    @id @default(uuid())
    threadId      String    @map("thread_id")
    userId        String    @map("user_id")
    lastReadAt    DateTime? @map("last_read_at") // When user last read this thread
    notifyOnReply Boolean   @default(true) @map("notify_on_reply") // Notify on new replies
    joinedAt      DateTime  @default(now()) @map("joined_at")

    thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

    @@unique([threadId, userId])
    @@index([threadId])
    @@index([userId])
    @@map("thread_participants")
}

model Attachment {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    fileName  String   @map("file_name")
    fileUrl   String   @map("file_url")
    fileType  String   @map("file_type")
    fileSize  Int      @map("file_size")
    createdAt DateTime @default(now()) @map("created_at")

    message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@index([messageId])
    @@map("attachments")
}

model Reaction {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    userId    String   @map("user_id")
    emoji     String
    createdAt DateTime @default(now()) @map("created_at")

    message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@unique([messageId, userId, emoji])
    @@index([messageId])
    @@map("reactions")
}

// ============================================
// DIRECT MESSAGES
// ============================================

model DirectMessageChannel {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now()) @map("created_at")

    participants DirectMessageParticipant[]
    messages     DirectMessage[]

    @@map("dm_channels")
}

model DirectMessageParticipant {
    id         String    @id @default(uuid())
    channelId  String    @map("channel_id")
    userId     String    @map("user_id")
    lastReadAt DateTime? @map("last_read_at") // Track when user last read DMs

    channel DirectMessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
    user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([channelId, userId], name: "channelId_userId")
    @@index([userId])
    @@index([channelId])
    @@map("dm_participants")
}

model DirectMessage {
    id        String    @id @default(uuid())
    channelId String    @map("channel_id")
    authorId  String    @map("author_id")
    content   String
    edited    Boolean   @default(false)
    isPinned  Boolean   @default(false) @map("is_pinned")
    pinnedAt  DateTime? @map("pinned_at")
    pinnedBy  String?   @map("pinned_by")
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    channel     DirectMessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
    author      User                 @relation("DirectMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
    attachments DMAttachment[]
    reactions   DMReaction[]
    bookmarks   BookmarkedMessage[]

    @@index([channelId, createdAt])
    @@index([channelId, isPinned, createdAt]) // Optimize pinned DM queries
    @@index([authorId])
    @@map("direct_messages")
}

model DMAttachment {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    fileName  String   @map("file_name")
    fileUrl   String   @map("file_url")
    fileType  String   @map("file_type")
    fileSize  Int      @map("file_size")
    createdAt DateTime @default(now()) @map("created_at")

    message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@index([messageId])
    @@map("dm_attachments")
}

model DMReaction {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    userId    String   @map("user_id")
    emoji     String
    createdAt DateTime @default(now()) @map("created_at")

    message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@unique([messageId, userId, emoji])
    @@index([messageId])
    @@map("dm_reactions")
}

// ============================================
// USER PRESENCE & STATUS (cached, not from Boxtime)
// ============================================

model UserPresence {
    userId       String     @id @map("user_id")
    status       UserStatus @default(OFFLINE)
    customStatus String?    @map("custom_status")
    lastSeen     DateTime   @default(now()) @map("last_seen")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("user_presence")
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
    id        String   @id @default(uuid())
    userId    String   @map("user_id")
    endpoint  String   @unique
    p256dh    String // Public key from client
    auth      String // Auth secret from client
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("push_subscriptions")
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
    id          String   @id @default(uuid())
    workspaceId String   @map("workspace_id")
    userId      String   @map("user_id") // Who performed the action
    action      String // Action type: USER_KICK, USER_BAN, CHANNEL_CREATE, etc.
    targetId    String?  @map("target_id") // ID of affected entity
    targetType  String?  @map("target_type") // Type of target: USER, CHANNEL, MESSAGE
    metadata    Json? // Additional action details
    ipAddress   String?  @map("ip_address")
    userAgent   String?  @map("user_agent")
    createdAt   DateTime @default(now()) @map("created_at")

    @@index([workspaceId])
    @@index([userId])
    @@index([createdAt])
    @@map("audit_logs")
}

// ============================================
// BOOKMARKED MESSAGES
// ============================================

model BookmarkedMessage {
    id          String   @id @default(uuid())
    userId      String   @map("user_id")
    messageId   String?  @map("message_id")
    dmMessageId String?  @map("dm_message_id")
    workspaceId String?  @map("workspace_id")
    note        String? // Optional user note
    createdAt   DateTime @default(now()) @map("created_at")

    user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    message   Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
    dmMessage DirectMessage? @relation(fields: [dmMessageId], references: [id], onDelete: Cascade)
    workspace Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@unique([userId, messageId])
    @@unique([userId, dmMessageId])
    @@index([userId])
    @@index([messageId])
    @@index([dmMessageId])
    @@index([createdAt])
    @@map("bookmarked_messages")
}

// ============================================
// POLLS
// ============================================

model Poll {
    id          String    @id @default(uuid())
    messageId   String    @unique @map("message_id")
    channelId   String    @map("channel_id")
    creatorId   String    @map("creator_id")
    question    String
    isMultiple  Boolean   @default(false) @map("is_multiple")
    isAnonymous Boolean   @default(false) @map("is_anonymous")
    endsAt      DateTime? @map("ends_at")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")

    message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
    channel Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
    creator User         @relation(fields: [creatorId], references: [id])
    options PollOption[]

    @@index([channelId])
    @@index([creatorId])
    @@map("polls")
}

model PollOption {
    id       String @id @default(uuid())
    pollId   String @map("poll_id")
    text     String
    position Int    @default(0)

    poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
    votes PollVote[]

    @@index([pollId])
    @@map("poll_options")
}

model PollVote {
    id        String   @id @default(uuid())
    optionId  String   @map("option_id")
    userId    String   @map("user_id")
    createdAt DateTime @default(now()) @map("created_at")

    option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
    voter  User       @relation(fields: [userId], references: [id])

    @@unique([optionId, userId])
    @@index([optionId])
    @@index([userId])
    @@map("poll_votes")
}

// ============================================
// ENUMS
// ============================================

enum MemberRole {
    OWNER
    ADMIN
    MEMBER
}

enum ChannelType {
    TEXT
    ANNOUNCEMENT
    THREAD
    VOICE
}

enum UserStatus {
    ONLINE
    AWAY
    BUSY
    OFFLINE
}

// ============================================
// VOICE CHANNELS
// ============================================

model VoiceSession {
    id        String    @id @default(uuid())
    channelId String    @map("channel_id")
    userId    String    @map("user_id")
    joinedAt  DateTime  @default(now()) @map("joined_at")
    leftAt    DateTime? @map("left_at")

    // WebRTC connection metadata
    isMuted    Boolean @default(false) @map("is_muted")
    isDeafened Boolean @default(false) @map("is_deafened")
    isSpeaking Boolean @default(false) @map("is_speaking")

    channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([channelId])
    @@index([userId])
    @@index([channelId, userId, leftAt])
    @@map("voice_sessions")
}

// ============================================
// MESSAGE TEMPLATES
// ============================================

model MessageTemplate {
    id        String   @id @default(uuid())
    userId    String   @map("user_id")
    name      String // Template display name
    content   String // Template message content
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
    @@map("message_templates")
}

// ============================================
// CHANNEL WEBHOOKS (Bot Integration)
// ============================================

model ChannelWebhook {
    id          String   @id @default(uuid())
    channelId   String   @map("channel_id")
    name        String // Display name for the webhook/bot
    avatarUrl   String?  @map("avatar_url") // Custom avatar for webhook messages
    token       String   @unique // Secret token for posting messages
    createdBy   String   @map("created_by") // User ID who created the webhook
    isActive    Boolean  @default(true) @map("is_active")
    description String? // What this webhook is used for
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

    @@index([channelId])
    @@index([token])
    @@map("channel_webhooks")
}
