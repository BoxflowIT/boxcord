// Boxcord Database Schema
// Chat system for Boxflow integrated with Boxtime

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================
// USERS (local cache of Boxtime users)
// ============================================

model User {
    id        String   @id // Same as Cognito sub / Boxtime user.id
    email     String   @unique
    firstName String?  @map("first_name")
    lastName  String?  @map("last_name")
    avatarUrl String?  @map("avatar_url")
    bio       String?
    role      String   @default("STAFF") // SUPER_ADMIN | ADMIN | STAFF
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    presence       UserPresence?
    messages       Message[]
    dmParticipants DirectMessageParticipant[]

    @@map("users")
}

// ============================================
// CHANNELS & WORKSPACES
// ============================================

model Workspace {
    id          String   @id @default(uuid())
    name        String
    description String?
    iconUrl     String?
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    channels Channel[]
    members  WorkspaceMember[]

    @@map("workspaces")
}

model WorkspaceMember {
    id          String     @id @default(uuid())
    workspaceId String     @map("workspace_id")
    userId      String     @map("user_id") // References Boxtime user.id (Cognito sub)
    role        MemberRole @default(MEMBER)
    joinedAt    DateTime   @default(now()) @map("joined_at")

    workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

    @@unique([workspaceId, userId])
    @@map("workspace_members")
}

model Channel {
    id          String      @id @default(uuid())
    workspaceId String      @map("workspace_id")
    name        String
    description String?
    type        ChannelType @default(TEXT)
    isPrivate   Boolean     @default(false) @map("is_private")
    createdAt   DateTime    @default(now()) @map("created_at")
    updatedAt   DateTime    @updatedAt @map("updated_at")

    workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
    messages  Message[]
    members   ChannelMember[]

    @@unique([workspaceId, name])
    @@map("channels")
}

model ChannelMember {
    id        String   @id @default(uuid())
    channelId String   @map("channel_id")
    userId    String   @map("user_id")
    joinedAt  DateTime @default(now()) @map("joined_at")

    channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

    @@unique([channelId, userId])
    @@map("channel_members")
}

// ============================================
// MESSAGES
// ============================================

model Message {
    id        String   @id @default(uuid())
    channelId String   @map("channel_id")
    authorId  String   @map("author_id") // References Boxtime user.id
    content   String
    edited    Boolean  @default(false)
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Reply threading
    parentId String?   @map("parent_id")
    parent   Message?  @relation("ThreadReplies", fields: [parentId], references: [id])
    replies  Message[] @relation("ThreadReplies")

    channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
    author      User         @relation(fields: [authorId], references: [id])
    attachments Attachment[]
    reactions   Reaction[]

    @@index([channelId, createdAt])
    @@map("messages")
}

model Attachment {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    fileName  String   @map("file_name")
    fileUrl   String   @map("file_url")
    fileType  String   @map("file_type")
    fileSize  Int      @map("file_size")
    createdAt DateTime @default(now()) @map("created_at")

    message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@map("attachments")
}

model Reaction {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    userId    String   @map("user_id")
    emoji     String
    createdAt DateTime @default(now()) @map("created_at")

    message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@unique([messageId, userId, emoji])
    @@map("reactions")
}

// ============================================
// DIRECT MESSAGES
// ============================================

model DirectMessageChannel {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now()) @map("created_at")

    participants DirectMessageParticipant[]
    messages     DirectMessage[]

    @@map("dm_channels")
}

model DirectMessageParticipant {
    id        String @id @default(uuid())
    channelId String @map("channel_id")
    userId    String @map("user_id")

    channel DirectMessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
    user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([channelId, userId])
    @@map("dm_participants")
}

model DirectMessage {
    id        String   @id @default(uuid())
    channelId String   @map("channel_id")
    authorId  String   @map("author_id")
    content   String
    edited    Boolean  @default(false)
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    channel     DirectMessageChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
    attachments DMAttachment[]
    reactions   DMReaction[]

    @@index([channelId, createdAt])
    @@map("direct_messages")
}

model DMAttachment {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    fileName  String   @map("file_name")
    fileUrl   String   @map("file_url")
    fileType  String   @map("file_type")
    fileSize  Int      @map("file_size")
    createdAt DateTime @default(now()) @map("created_at")

    message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@map("dm_attachments")
}

model DMReaction {
    id        String   @id @default(uuid())
    messageId String   @map("message_id")
    userId    String   @map("user_id")
    emoji     String
    createdAt DateTime @default(now()) @map("created_at")

    message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

    @@unique([messageId, userId, emoji])
    @@map("dm_reactions")
}

// ============================================
// USER PRESENCE & STATUS (cached, not from Boxtime)
// ============================================

model UserPresence {
    userId       String     @id @map("user_id")
    status       UserStatus @default(OFFLINE)
    customStatus String?    @map("custom_status")
    lastSeen     DateTime   @default(now()) @map("last_seen")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("user_presence")
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
    id        String   @id @default(uuid())
    userId    String   @map("user_id")
    endpoint  String   @unique
    p256dh    String // Public key from client
    auth      String // Auth secret from client
    createdAt DateTime @default(now()) @map("created_at")

    @@index([userId])
    @@map("push_subscriptions")
}

// ============================================
// ENUMS
// ============================================

enum MemberRole {
    OWNER
    ADMIN
    MEMBER
}

enum ChannelType {
    TEXT
    ANNOUNCEMENT
    THREAD
}

enum UserStatus {
    ONLINE
    AWAY
    BUSY
    OFFLINE
}
