{
  "name": "boxcord",
  "version": "1.21.5",
  "description": "Internal chat system for Boxflow - Discord-like chat integrated with Boxtime",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/apps/api/index.ts",
    "dev:full": "docker compose up -d && yarn dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "build": "tsc && cd client && yarn install --production=false --ignore-engines && yarn build",
    "start": "echo '🚀 Starting Boxcord...' && prisma migrate deploy && echo '✅ Migrations complete' && node dist/apps/api/index.js",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate && husky install",
    "prisma:generate": "prisma generate",
    "prisma:migrate-dev": "prisma migrate dev",
    "prisma:migrate-deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run tests/load/api-load-test.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "validate": "./scripts/pre-push.sh",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.19.2",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.39.0",
    "@sentry/react": "^10.39.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.70.0",
    "cheerio": "^1.2.0",
    "dompurify": "3.3.2",
    "dotenv-safe": "^9.1.0",
    "fastify": "5.8.2",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "web-push": "^3.6.7",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.33",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "prettier": "^3.2.5",
    "prisma": "^6.19.2",
    "rollup": "^4.59.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "fast-xml-parser": "^5.3.6",
    "minimatch": "^10.2.3"
  },
  "resolutions": {
    "minimatch": "^10.2.3",
    "flatted": ">=3.4.0",
    "undici": ">=7.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
