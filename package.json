    "flatted": ">=3.4.2",
    "undici": ">=7.24.0",
    "socket.io-parser": ">=4.2.6",
    "fast-xml-parser": ">=5.7.0",
    "effect": ">=3.20.0",
    "micromatch/picomatch": "^2.3.2",
    "brace-expansion": ">=5.0.6",
    "yaml": ">=2.8.3",
    "defu": ">=6.1.5",
    "vite": "^7.3.5",
    "fast-jwt": ">=6.2.4",
    "follow-redirects": ">=1.16.0",
    "axios": ">=1.15.2",
    "@fastify/static": "9.1.3",
    "dompurify": "^3.4.11",
    "postcss": ">=8.5.12",
    "fast-uri": ">=3.1.2",
    "fast-xml-builder": ">=1.2.0",
    "ws": ">=8.20.2",
    "esbuild": "^0.28.1",
    "form-data": ">=4.0.6",
    "@opentelemetry/core": ">=2.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
